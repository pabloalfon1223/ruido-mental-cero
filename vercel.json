{
          "version": 2,
          "builds": [
                      {
                                    "src": "index.html",
                                    "use": "@vercel/static"
                      }
          ],
          "headers": [
                      {
                                    "source": "/(.*)",
                                    "headers": [
                                                    {
                                                                      "key": "Content-Type",
                                                                      "value": "text/html; charset=utf-8"
                                                    }
                                    ]
                      }
          ]
}
